---
const phases = [
  {
    status: 'DONE',
    statusLabel: '',
    title: 'The Open Source Engine',
    description: 'Multi-phase pipeline, 7 analytical lenses, LLM convergence. ICP profiles, activation maps, measurement specs. CLI, MCP server, and Docker.',
    isActive: false,
    isDone: true
  },
  {
    status: 'NOW',
    statusLabel: 'In Progress',
    title: 'Refinement Loop',
    description: 'MCP tools for profile retrieval and updates. Cascading updates — change activation and measurement specs auto-adjust. Confidence tracking and suggestion engine.',
    isActive: true,
    isDone: false
  },
  {
    status: 'NEXT',
    statusLabel: '',
    title: 'Extended Sources',
    description: 'YouTube analysis, documentation parsing, G2 and review mining. Benchmark database to compare your growth model against similar products.',
    isActive: false,
    isDone: false
  },
  {
    status: 'FUTURE',
    statusLabel: '',
    title: 'Connected Intelligence',
    description: 'Amplitude, Mixpanel, and Segment connectors. Gap analysis between your tracking and your ideal plan. Live metrics from your actual data.',
    isActive: false,
    isDone: false
  }
];
---

<section class="section-padding">
  <div class="container-content">
    <h2 class="heading-2 text-center mb-4">
      Where we're headed
    </h2>

    <p class="body-text text-center mb-12">
      Basesignal is being built in the open. The core engine is shipped — here's what's next.
    </p>

    <!-- Phase Cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {phases.map((phase) => (
        <div class:list={['card', { 'border-accent': phase.isActive, 'opacity-60': !phase.isActive && !phase.isDone }]}>
          <div class="flex items-center gap-2 mb-4">
            <span class:list={[
              'text-xs font-medium px-2 py-1 rounded',
              phase.isActive ? 'bg-accent/20 text-accent' : phase.isDone ? 'bg-green-500/20 text-green-400' : 'bg-bg-subtle text-text-muted'
            ]}>
              {phase.status}
            </span>
            {phase.statusLabel && (
              <span class="text-text-muted text-sm">{phase.statusLabel}</span>
            )}
          </div>
          <h3 class="text-lg font-semibold mb-3">{phase.title}</h3>
          <p class="text-text-secondary text-sm">
            {phase.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
