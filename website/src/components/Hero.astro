---
const githubUrl = 'https://github.com/deepskydatahq/basesignal';
---

<section class="section-padding">
  <div class="container-content">
    <!-- Header -->
    <header class="flex items-center justify-center mb-16 md:mb-24">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center p-1.5">
          <img src="/basesignal_logo_white.svg" alt="Basesignal logo" class="w-full h-full" />
        </div>
        <span class="text-xl font-semibold">Basesignal</span>
      </div>
    </header>

    <!-- Hero Content -->
    <div class="text-center max-w-4xl mx-auto">
      <p class="text-accent text-sm font-medium tracking-wide uppercase mb-4">Open Source</p>
      <h1 class="heading-1 mb-6">
        Context engineering for growth intelligence
      </h1>
      <p class="body-text max-w-2xl mx-auto mb-4">
        Point Basesignal at a URL. Get a structured growth profile — ICP profiles, activation maps, value moments, measurement specs — in 60 seconds.
      </p>
      <p class="text-text-muted max-w-2xl mx-auto mb-10">
        No data required. No signup. Just run it.
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <div class="bg-bg-elevated border border-border-default rounded-lg px-5 py-3 font-mono text-sm text-text-secondary">
          npx basesignal scan https://your-product.com
        </div>
        <a href={githubUrl} class="btn-primary flex items-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
  </div>
</section>
